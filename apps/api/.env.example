# ============================================
# KAZI API - Environment Variables
# Copy to .env.local for local development
# NEVER commit .env.local to git
# ============================================

# App
NODE_ENV=development
PORT=3001
PUBLIC_API_URL=http://localhost:3001

# JWT - CHANGE THESE IN PRODUCTION!
JWT_SECRET=kazi-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# PostgreSQL
# Production target: AWS RDS PostgreSQL in af-south-1
# Development can use any PostgreSQL-compatible connection string
DATABASE_URL=postgresql://kazi_app:[YOUR-PASSWORD]@[YOUR-RDS-ENDPOINT]:5432/kazi_db

# Redis
# Production target: AWS ElastiCache Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Clickatell SMS (SA) - https://www.clickatell.com/
CLICKATELL_API_KEY=

# Firebase (Push Notifications) - https://console.firebase.google.com/
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Google Maps Platform - https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# Peach Payments (SA card processing) - https://developer.peachpayments.com/
PEACH_PAYMENTS_ENTITY_ID=
PEACH_PAYMENTS_SECRET=
PEACH_PAYMENTS_MODE=test

# Twilio (In-app calling) - https://www.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS S3 (Document uploads and media)
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=kazi-uploads

# Commission
DEFAULT_COMMISSION_RATE=0.15

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
