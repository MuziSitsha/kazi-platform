# ============================================
# KAZI API - Environment Variables
# Copy to .env.local for local development
# NEVER commit .env.local to git
# ============================================

# App
NODE_ENV=development
PORT=3001

# JWT - CHANGE THESE IN PRODUCTION!
JWT_SECRET=kazi-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# PostgreSQL (Supabase connection string)
# Get this from: Supabase Dashboard > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Redis (Railway provides this when you add Redis service)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Clickatell SMS (SA) - https://www.clickatell.com/
CLICKATELL_API_KEY=

# Firebase (Push Notifications) - https://console.firebase.google.com/
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Google Maps Platform - https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# Peach Payments (SA card processing) - https://developer.peachpayments.com/
PEACH_PAYMENTS_ENTITY_ID=
PEACH_PAYMENTS_SECRET=
PEACH_PAYMENTS_MODE=test

# Twilio (In-app calling) - https://www.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Cloudflare R2 (File storage - much cheaper than S3)
# Get from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kazi-uploads

# Commission
DEFAULT_COMMISSION_RATE=0.15

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
